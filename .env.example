# このファイルを .env にコピーして値を設定してください(.env はgit管理対象外です)

# DuckDNS等で取得した独自サブドメイン(例: office-yourname.duckdns.org)
DOMAIN=office-yourname.duckdns.org

# セッション署名用の秘密鍵。ランダムな文字列に変更してください(例: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-string

# 初回起動時の管理者パスワード(起動後に設定画面から変更可能)
INITIAL_ADMIN_PASSWORD=change-me
